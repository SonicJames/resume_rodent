{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/job-chat.js": { "maxDuration": 30 },
    "api/exchange.js": { "maxDuration": 30 },
    "api/chat.js": { "maxDuration": 30 },
    "api/export.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
